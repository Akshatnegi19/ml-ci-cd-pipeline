   "source": [
    "# Generate iris.csv\n",
    "import pandas as pd\n",
    "from sklearn.datasets import load_iris"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "e3dc64d9-31e3-411f-808d-9ab87dac0fa6",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load Iris Dataset \n",
    "\n",
    "iris = load_iris()\n",
    "df = pd.DataFrame(data=iris,columns=iris.feature_names)\n",
    "df[\"species\"]=iris.target"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "fe2faae2-da7c-42e7-b900-60b72b497893",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Save to CSV\n",
    "\n",
    "df.to_csv(\"iris.csv\",index=False)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "bf051d67-7971-445a-a3c2-fa713dc512af",
